    "827ff746-c592-4127-a69c-4fadd906c01b": {
      "id": "827ff746-c592-4127-a69c-4fadd906c01b",
      "graph_id": "ff06ce9c-31d9-4828-8f35-db1ab4f100fa",
      "type": "custom",
      "label": "Kết thúc",
      "content": "Điều 64, nghị định 34/2016/NĐ-CP:\n\nChức vụ, họ tên và chữ ký của người có thẩm quyền ban hành văn bản pháp luật đó. Trong trường hợp ký thay cũng phải thể hiện rõ ràng ràng và có ghi tắt “KT” ở bên cạnh. \n\nDấu của cơ quan ban hành văn bản đóng ngay sau khi có chữ ký của người có thẩm quyền. \n\nNơi nhận gồm các cơ quan giám sát, kiểm tra, ban hành và các cơ quan  khác tùy văn bản",
      "x": 46.33705078858384,
      "y": 558.5520918621754,
      "created_at": "2026-05-05T20:31:35.337045",
      "updated_at": "2026-05-05T21:45:43.424181"
    },
